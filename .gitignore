# Python bytecode and cache directories
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.pytest-tmp/
.ruff_cache/
.mypy_cache/
.pyre/
.pytype/
.coverage
.coverage.*
htmlcov/

# Virtual environments
.venv/
venv/
env/
ENV/

# Build and packaging artifacts
build/
dist/
*.egg-info/
*.egg
pip-wheel-metadata/

# Tooling and test environments
.tox/
.nox/
.hypothesis/
.claude/

# Local environment and secrets
.env
.env.*
!.env.example

# Editor and OS metadata
.idea/
.vscode/
*.swp
*.swo
.DS_Store
Thumbs.db
desktop.ini

# Logs and local scratch files
*.log
*.tmp
*.temp
.litlaunch/

# Documentation policy for this public repository:
# Public docs remain tracked. Private/internal/scratch notes stay local.
# The former docs/internal tree is intentionally ignored so sensitive
# development records cannot be re-added to the public GitHub source tree.
notes/
scratch/
docs/internal/
# Host-sizing research and validation notebooks are retained locally; only
# docs/research/.gitkeep belongs in the public repository.
docs/research/*.md
# Internal audit/remediation records reference internal findings and
# pre-release integration work; they stay local-only like research notes.
# Only docs/audits/.gitkeep is tracked.
docs/audits/*.md
docs/**/scratch/
docs/**/tmp/
docs/**/inbox/
docs/private/
docs/local/
